<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
	<!-- Тёмный цвет с альфа-каналом CC (примерно 80% прозрачности) -->
	<solid android:color="#EE1C1C1E" />

	<!-- Скругляем углы панели -->
	<corners android:radius="30dp" />
	
	<!-- Тонкая аккуратная рамка, чтобы панель не сливалась с темным фоном YouTube -->
	<stroke android:width="1dp" android:color="#11FFFFFF" />
</shape>