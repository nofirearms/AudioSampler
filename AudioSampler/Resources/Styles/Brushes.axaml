<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
      <Border Padding="20" Background="{StaticResource StripedBrush}"/>
  </Design.PreviewWith>

    <SolidColorBrush x:Key="Background1" Color="#1b1b1b"></SolidColorBrush>
    <SolidColorBrush x:Key="Background2" Color="#222222"></SolidColorBrush>
    <SolidColorBrush x:Key="Background3" Color="#2f2f2f"></SolidColorBrush>
    <SolidColorBrush x:Key="AccentBrush1" Color="#ffa500"/>
    <SolidColorBrush x:Key="AccentBrush2" Color="#d08600"/>
    <SolidColorBrush x:Key="InactiveForeground1" Color="#a1a1a1"></SolidColorBrush>

    <VisualBrush x:Key="StripedBrush" 
                 TileMode="Tile" 
                 Stretch="None"
                 SourceRect="0,0,40,40" 
                 DestinationRect="0,0,40,40">
        <VisualBrush.Visual>
            <Canvas Width="40" Height="40" Background="Transparent">
                <Path Data="M 0,40 L 40,0 M -10,10 L 10,-10 M 30,50 L 50,30" 
                      Stroke="White" 
                      StrokeThickness="14" 
                      Opacity="0.05"/>
            </Canvas>
        </VisualBrush.Visual>
    </VisualBrush>

</ResourceDictionary>
