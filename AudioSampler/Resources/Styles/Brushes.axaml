<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
      <Border Padding="20" Background="{StaticResource StripedBrush}"/>
  </Design.PreviewWith>

    <SolidColorBrush x:Key="Background1" Color="{DynamicResource BackgroundColor1}"/>
    <SolidColorBrush x:Key="Background2" Color="{DynamicResource BackgroundColor2}"/>
    <SolidColorBrush x:Key="Background3" Color="{DynamicResource BackgroundColor3}"/>
    <SolidColorBrush x:Key="AccentBrush1" Color="{DynamicResource AccentColor1}"/>
    <SolidColorBrush x:Key="AccentBrush2" Color="{DynamicResource AccentColor2}"/>
    <SolidColorBrush x:Key="AccentBrush3" Color="{DynamicResource AccentColor3}"/>
    <SolidColorBrush x:Key="InactiveForeground1" Color="{DynamicResource InactiveColor1}"/>



    <VisualBrush x:Key="StripedBrush" 
                 TileMode="Tile" 
                 Stretch="None"
                 SourceRect="0,0,40,40" 
                 DestinationRect="0,0,40,40">
        <VisualBrush.Visual>
            <Canvas Width="40" Height="40" Background="Transparent">
                <Path Data="M 0,40 L 40,0 M -10,10 L 10,-10 M 30,50 L 50,30" 
                      Stroke="White" 
                      StrokeThickness="14" 
                      Opacity="0.05"/>
            </Canvas>
        </VisualBrush.Visual>
    </VisualBrush>

</ResourceDictionary>
