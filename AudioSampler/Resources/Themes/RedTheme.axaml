<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BackgroundColor1">#1b1b1b</Color>
    <Color x:Key="BackgroundColor2">#222222</Color>
    <Color x:Key="BackgroundColor3">#2f2f2f</Color>

    <Color x:Key="AccentColor1">#eb6262</Color>
    <Color x:Key="AccentColor2">#bd4f4f</Color>
    <Color x:Key="AccentColor3">#913d3d</Color>

    <Color x:Key="InactiveColor1">#a1a1a1</Color>
    <Color x:Key="SelectedListBoxItemColor1">White</Color>

</ResourceDictionary>
